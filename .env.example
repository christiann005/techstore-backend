# Configuración de Base de Datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=techstore_db

# Configuración de MongoDB
MONGO_URI=mongodb://localhost:27017/techstore_db

# Configuración de Stripe (Obligatorio)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT Config (Mínimo 16 caracteres)
JWT_SECRET=super_secret_techstore_key_2026

# App Config
PORT=3000
NODE_ENV=development

# Configuración de Correo (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=no-reply@techstore.com
